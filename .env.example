# ═══════════════════════════════════════════════════════════
# Dealer Portal — Environment Variables
#
# REQUIRED for deployment (only these 3):
#   DATABASE_URL    — automatically set by Railway when you link Postgres
#   AUTH_SECRET     — generate with: openssl rand -base64 32
#   AUTH_URL        — your app's public URL (e.g., https://portal.client.com)
#
# Everything else is optional or configured via the admin panel.
# ═══════════════════════════════════════════════════════════

# ─── Required ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/dealer_portal
AUTH_SECRET=
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# ─── Email (optional — emails log to console if not set) ──
RESEND_API_KEY=
EMAIL_FROM=noreply@example.com

# ─── File Uploads (optional) ──────────────────────────────
# RAILWAY_VOLUME_MOUNT_PATH=/data

# ─── Development Only ─────────────────────────────────────
# DATABASE_TEST_URL=postgresql://user:password@localhost:5432/dealer_portal_test
# UPLOADS_DIR=public/uploads
# OWNER_EMAIL=admin@example.com
# OWNER_PASSWORD=password

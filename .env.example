# ═══════════════════════════════════════════════════════════
# Dealer Portal — Environment Configuration
# Copy to .env.local for local development
# ═══════════════════════════════════════════════════════════

# ─── Database (required) ──────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/dealer_portal

# Test database (optional — used by integration tests)
DATABASE_TEST_URL=postgresql://user:password@localhost:5432/dealer_portal_test

# ─── Authentication (required) ────────────────────────────
# Session encryption key — generate with: openssl rand -base64 32
AUTH_SECRET=

# Base URL for auth callbacks
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# ─── Email via Resend (optional) ─────────────────────────
# Without RESEND_API_KEY, emails log to console instead of sending
# Get a key at https://resend.com
RESEND_API_KEY=

# "From" address for all outgoing emails (must be verified in Resend)
EMAIL_FROM=noreply@example.com

# Fallback admin email for contact form notifications
ADMIN_EMAIL=admin@example.com

# ─── Seed Data (dev only) ─────────────────────────────────
# Only used by the seed script (npm run db:seed) for development.
# Production uses the setup wizard instead — no env vars needed.
# OWNER_EMAIL=admin@example.com
# OWNER_PASSWORD=password

# ─── File Uploads (optional) ─────────────────────────────
# Override the upload directory (default: public/uploads)
# UPLOADS_DIR=/path/to/custom/uploads

# Railway persistent volume (auto-set by Railway when volume attached)
# RAILWAY_VOLUME_MOUNT_PATH=/data

# ─── S3/R2 Backup for Uploads (optional) ─────────────────
# When set, uploaded files are dual-written to S3/R2 as a backup.
# Uses the same credentials as the backup cron service.
# BACKUP_S3_BUCKET=my-backups
# BACKUP_S3_PREFIX=client-name/
# BACKUP_S3_ENDPOINT=              # For R2: https://<account>.r2.cloudflarestorage.com
# BACKUP_S3_ACCESS_KEY=
# BACKUP_S3_SECRET_KEY=
# BACKUP_S3_REGION=auto

# ─── Application URL (recommended) ───────────────────────
# Used in email templates for links (login, order detail, etc.)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

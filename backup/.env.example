# ═══════════════════════════════════════════════════════════
# Dealer Portal — Backup Service Configuration
# ═══════════════════════════════════════════════════════════

# Database to back up (required)
# Use the same DATABASE_URL as the main app, or a read replica
BACKUP_DATABASE_URL=postgresql://user:password@host:5432/dealer_portal

# S3-compatible storage (required)
BACKUP_S3_BUCKET=my-backups
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=

# For Cloudflare R2: https://<account-id>.r2.cloudflarestorage.com
# For AWS S3: leave empty (uses default AWS endpoints)
BACKUP_S3_ENDPOINT=

# Region (use "auto" for R2, or your AWS region like "us-east-1")
BACKUP_S3_REGION=auto

# Prefix path within the bucket (one per client)
# Example: "acme-hardware/" or "client-123/"
BACKUP_S3_PREFIX=client-name/

# Retention (how many backups to keep per tier)
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4
BACKUP_RETENTION_MONTHLY=3

# Failure alerts (optional)
# If set, sends an email when a backup fails
BACKUP_ALERT_EMAIL=admin@example.com
BACKUP_ALERT_FROM=noreply@example.com
RESEND_API_KEY=

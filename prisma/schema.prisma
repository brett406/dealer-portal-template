generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────
// Enums
// ──────────────────────────────────────

enum Role {
  SUPER_ADMIN
  STAFF
  CUSTOMER
}

enum ApprovalStatus {
  APPROVED
  PENDING
  REJECTED
}

enum OrderStatus {
  RECEIVED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum Currency {
  CAD
  USD
}

// ──────────────────────────────────────
// Auth & Users
// ──────────────────────────────────────

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  password           String
  name               String
  role               Role     @default(CUSTOMER)
  mustChangePassword Boolean  @default(true)
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  customer            Customer?
  ordersPlacedAsAdmin Order[]              @relation("PlacedByAdmin")
  statusChanges       OrderStatusHistory[]
  passwordResets      PasswordReset[]
  auditLogs           AuditLog[]
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([token, expiresAt])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ipAddress String
  success   Boolean
  createdAt DateTime @default(now())

  @@index([email, ipAddress, createdAt])
}

// Windowed counter for public-form rate limiting (contact, register,
// become-a-dealer, password reset). DB-backed so limits hold across multiple
// app instances / redeploys, unlike the previous in-memory Map. See lib/rate-limit.ts.
model RateLimit {
  key     String   @id
  count   Int      @default(0)
  resetAt DateTime

  @@index([resetAt])
}

// ──────────────────────────────────────
// Tax Rates
// ──────────────────────────────────────

model TaxRate {
  id          String   @id @default(cuid())
  name        String   @unique
  label       String
  percent     Decimal  @db.Decimal(5, 2)
  description String?
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companies Company[]
}

// ──────────────────────────────────────
// Companies & Customers
// ──────────────────────────────────────

model Company {
  id             String         @id @default(cuid())
  name           String
  priceLevelId   String
  taxRateId      String?
  // Order/display currency for this dealer. Selects which price column is read
  // (baseRetailPrice[Usd], priceOverride[Usd]). PriceLevel discount % is
  // currency-agnostic and applies to whichever currency's base price.
  currency       Currency       @default(CAD)
  phone          String?
  notes          String?
  active         Boolean        @default(true)
  approvalStatus ApprovalStatus @default(APPROVED)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  priceLevel PriceLevel @relation(fields: [priceLevelId], references: [id])
  taxRate    TaxRate?   @relation(fields: [taxRateId], references: [id])
  customers  Customer[]
  addresses  Address[]
  orders     Order[]
}

model Customer {
  id        String   @id @default(cuid())
  companyId String
  userId    String   @unique
  name      String
  email     String
  phone     String?
  title     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
  cart    Cart?
  orders  Order[]
}

model Address {
  id         String   @id @default(cuid())
  companyId  String
  label      String
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String
  country    String   @default("CA")
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
}

// ──────────────────────────────────────
// Pricing
// ──────────────────────────────────────

model PriceLevel {
  id              String   @id @default(cuid())
  name            String
  discountPercent Decimal  @db.Decimal(5, 2)
  description     String?
  isDefault       Boolean  @default(false)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  companies Company[]
}

// ──────────────────────────────────────
// Products
// ──────────────────────────────────────

model ProductCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  featured    Boolean  @default(false)
  imageUrl    String?
  tags        String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products  Product[]
  materials Material[]
}

model Product {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  description      String?
  categoryId       String
  minOrderQuantity Int?
  madeToOrder      Boolean  @default(false)
  tags             String[] @default([])
  active           Boolean  @default(true)
  featured         Boolean  @default(false)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // BOM costing (docs/BOM-COSTING.md) — default for this product's variants
  priceFromBom          Boolean  @default(false)
  materialMarginPercent Decimal? @db.Decimal(5, 2)
  laborMarginPercent    Decimal? @db.Decimal(5, 2)

  category       ProductCategory    @relation(fields: [categoryId], references: [id])
  variants       ProductVariant[]
  images         ProductImage[]
  unitsOfMeasure ProductUOM[]
  accessories    ProductAccessory[] @relation("ProductAccessories")
  accessoryOf    ProductAccessory[] @relation("AccessoryOf")
  bomComponents  BomComponent[]
  bomLaborLines  BomLaborLine[]

  @@index([categoryId])
}

model ProductAccessory {
  id          String   @id @default(cuid())
  productId   String
  accessoryId String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  product   Product @relation("ProductAccessories", fields: [productId], references: [id])
  accessory Product @relation("AccessoryOf", fields: [accessoryId], references: [id])

  @@unique([productId, accessoryId])
  @@index([productId, sortOrder])
}

model ProductVariant {
  id                String   @id @default(cuid())
  productId         String
  name              String
  sku               String   @unique
  baseRetailPrice   Decimal  @db.Decimal(10, 2)
  // USD list price. Null = not yet priced in USD; USD dealers are blocked from
  // ordering such a variant rather than falling back to the CAD number.
  baseRetailPriceUsd Decimal? @db.Decimal(10, 2)
  stockQuantity     Int      @default(0)
  lowStockThreshold Int      @default(5)
  active            Boolean  @default(true)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // BOM costing (docs/BOM-COSTING.md) — per-variant override; null inherits Product
  priceFromBom          Boolean?
  materialMarginPercent Decimal? @db.Decimal(5, 2)
  laborMarginPercent    Decimal? @db.Decimal(5, 2)
  computedCost          Decimal? @db.Decimal(12, 4) // last rolled cost (display/audit only)

  product       Product        @relation(fields: [productId], references: [id])
  cartItems     CartItem[]
  orderItems    OrderItem[]
  bomComponents BomComponent[]
  bomLaborLines BomLaborLine[]
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  altText   String?
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
}

model ProductUOM {
  id               String   @id @default(cuid())
  productId        String
  name             String
  conversionFactor Int
  priceOverride    Decimal? @db.Decimal(10, 2)
  // USD per-UOM price override (parallels priceOverride for CAD).
  priceOverrideUsd Decimal? @db.Decimal(10, 2)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  product   Product    @relation(fields: [productId], references: [id])
  cartItems CartItem[]
}

// ──────────────────────────────────────
// Cart
// ──────────────────────────────────────

model Cart {
  id         String   @id @default(cuid())
  customerId String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer   @relation(fields: [customerId], references: [id])
  items    CartItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  variantId String
  uomId     String
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart           @relation(fields: [cartId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])
  uom     ProductUOM     @relation(fields: [uomId], references: [id])

  @@unique([cartId, variantId, uomId])
}

// ──────────────────────────────────────
// Orders
// ──────────────────────────────────────

model Order {
  id                      String      @id @default(cuid())
  orderNumber             String      @unique
  companyId               String
  customerId              String
  placedByAdminId         String?
  shippingAddressId       String?
  status                  OrderStatus @default(RECEIVED)
  subtotal                Decimal     @db.Decimal(10, 2)
  shippingCost            Decimal     @default(0) @db.Decimal(10, 2)
  taxRateSnapshot         String?
  taxPercentSnapshot      Decimal?    @db.Decimal(5, 2)
  taxAmount               Decimal     @default(0) @db.Decimal(10, 2)
  total                   Decimal     @db.Decimal(10, 2)
  poNumber                String?
  notes                   String?
  internalNotes           String?
  priceLevelSnapshot      String
  discountPercentSnapshot Decimal     @db.Decimal(5, 2)
  // Currency the order was placed in, frozen at submit. All money fields on this
  // order and its items are denominated in this currency.
  currency                Currency    @default(CAD)
  submittedAt             DateTime
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  company       Company              @relation(fields: [companyId], references: [id])
  customer      Customer             @relation(fields: [customerId], references: [id])
  placedByAdmin User?                @relation("PlacedByAdmin", fields: [placedByAdminId], references: [id])
  items         OrderItem[]
  statusHistory OrderStatusHistory[]

  @@index([companyId, status, submittedAt])
}

model OrderItem {
  id                      String   @id @default(cuid())
  orderId                 String
  variantId               String
  productNameSnapshot     String
  variantNameSnapshot     String
  skuSnapshot             String
  uomNameSnapshot         String
  uomConversionSnapshot   Int
  quantity                Int
  baseUnitQuantity        Int
  unitPrice               Decimal  @db.Decimal(10, 2)
  baseRetailPriceSnapshot Decimal  @db.Decimal(10, 2)
  lineTotal               Decimal  @db.Decimal(10, 2)
  createdAt               DateTime @default(now())

  order   Order          @relation(fields: [orderId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])
}

model OrderStatusHistory {
  id          String      @id @default(cuid())
  orderId     String
  status      OrderStatus
  changedById String
  notes       String?
  createdAt   DateTime    @default(now())

  order     Order @relation(fields: [orderId], references: [id])
  changedBy User  @relation(fields: [changedById], references: [id])
}

// ──────────────────────────────────────
// CMS (inherited from Static Site Product)
// ──────────────────────────────────────

model SiteSetting {
  id                    String   @id @default(cuid())
  siteTitle             String
  siteDescription       String?
  defaultSeoTitle       String?
  defaultSeoDescription String?
  googleAnalyticsId     String?
  notificationEmail     String?
  contactEmail          String?
  contactPhone          String?
  contactAddress        String?
  defaultCountry        String   @default("CA")
  defaultMapCenterLat   Decimal? @db.Decimal(10, 6)
  defaultMapCenterLng   Decimal? @db.Decimal(10, 6)
  defaultMapZoom        Int      @default(4)
  updatedByEmail        String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // BOM costing (docs/BOM-COSTING.md) — master switch + site-default markups
  bomCostingEnabled            Boolean @default(false)
  defaultMaterialMarginPercent Decimal @default(0) @db.Decimal(5, 2)
  defaultLaborMarginPercent    Decimal @default(0) @db.Decimal(5, 2)
}

// ──────────────────────────────────────
// Public Locator Dealers
// ──────────────────────────────────────
// Distinct from Customer/Company (which are wholesale-account dealers
// that log in and order). LocatorDealer represents the public-facing
// store-locator entries — retail outlets the public can find.

model LocatorDealer {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  dealerType String?
  industries String[] @default([])

  // Address
  line1      String?
  line2      String?
  city       String?
  region     String?
  postalCode String?
  country    String  @default("CA")

  // Geocoded position (filled in on save by the geocoder)
  latitude  Decimal? @db.Decimal(10, 6)
  longitude Decimal? @db.Decimal(10, 6)

  // Contact
  phone   String?
  email   String?
  website String?

  notes     String?
  active    Boolean @default(true)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, region, sortOrder])
  @@index([active, dealerType])
}

model PageContent {
  id             String   @id @default(cuid())
  pageKey        String   @unique
  payload        Json
  seo            Json
  updatedByEmail String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PageGroupItem {
  id             String   @id @default(cuid())
  pageKey        String
  groupKey       String
  sortOrder      Int      @default(0)
  payload        Json
  updatedByEmail String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([pageKey, groupKey, sortOrder])
}

model CollectionItem {
  id             String   @id @default(cuid())
  collectionKey  String
  slug           String?
  published      Boolean  @default(false)
  sortOrder      Int      @default(0)
  payload        Json
  updatedByEmail String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([collectionKey, slug])
  @@index([collectionKey, published, sortOrder])
}

model AssetFolder {
  id             String   @id @default(cuid())
  name           String   @unique
  slug           String   @unique
  description    String?
  accentColor    String? // palette key: "slate" | "red" | "orange" | "blue" | "purple" | "green"
  sortOrder      Int      @default(0)
  updatedByEmail String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  assets Asset[]
}

model Asset {
  id             String   @id @default(cuid())
  filename       String
  originalName   String
  title          String?
  description    String?
  mimeType       String
  size           Int
  storagePath    String   @unique
  altText        String?
  folderId       String?
  updatedByEmail String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  folder AssetFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([folderId, createdAt])
}

model FormSubmission {
  id        String   @id @default(cuid())
  formKey   String
  payload   Json
  createdAt DateTime @default(now())

  @@index([formKey, createdAt])
}

model ContentRevision {
  id             String   @id @default(cuid())
  scope          String
  contentKey     String
  snapshot       Json
  createdByEmail String?
  createdAt      DateTime @default(now())

  @@index([scope, contentKey, createdAt])
}

// ──────────────────────────────────────
// Audit Log
// ──────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  targetId   String?
  targetType String?
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ──────────────────────────────────────
// BOM Costing & Pricing (docs/BOM-COSTING.md)
// Dormant by default: nothing here affects pricing unless
// SiteSetting.bomCostingEnabled AND an effective priceFromBom are true.
// ──────────────────────────────────────

enum MaterialKind {
  raw // leaf — unitCost is entered by the shop (editable standard cost)
  subassembly // node — cost is COMPUTED from its own BOM + labor (rolls up at cost)
}

model Material {
  id   String       @id @default(cuid())
  name String
  sku  String?      @unique
  unit String       @default("each") // display label: each, ft, lb, sheet, hr...
  kind MaterialKind @default(raw)

  // Leaf cost (raw): editable standard unit cost. Null/ignored for subassembly.
  unitCost Decimal? @db.Decimal(12, 4)

  // Denormalized rolled cost (subassembly): materials + labor of THIS material's
  // own BOM, at cost (no margin). Recomputed by the cost engine; display/audit
  // only — never read back mid-rollup. Mirrors unitCost for raw materials.
  computedCost Decimal? @db.Decimal(12, 4)

  categoryId String?
  category   ProductCategory? @relation(fields: [categoryId], references: [id])

  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // BOM edges where this material is the CHILD (consumed somewhere).
  usedIn     BomComponent[] @relation("ComponentMaterial")
  // BOM edges where this material is the PARENT (subassembly's own components).
  components BomComponent[] @relation("ParentMaterial")
  laborLines BomLaborLine[] @relation("ParentMaterialLabor")

  @@index([kind, archivedAt])
  @@index([categoryId])
}

// One BOM line: a parent consumes `quantity` of a child Material.
// Parent is exactly ONE of product / variant / material (sub-assembly) —
// enforced by a CHECK constraint in the migration SQL (Prisma can't express it).
model BomComponent {
  id String @id @default(cuid())

  productId        String?
  product          Product?        @relation(fields: [productId], references: [id], onDelete: Cascade)
  productVariantId String?
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  parentMaterialId String?
  parentMaterial   Material?       @relation("ParentMaterial", fields: [parentMaterialId], references: [id], onDelete: Cascade)

  materialId String
  material   Material @relation("ComponentMaterial", fields: [materialId], references: [id], onDelete: Restrict)

  quantity Decimal @db.Decimal(12, 4) // per ONE unit of the parent
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([productVariantId])
  @@index([parentMaterialId])
  @@index([materialId])
}

model LaborRate {
  id          String    @id @default(cuid())
  name        String    @unique // "Welder", "Assembly", "Painter"
  ratePerHour Decimal   @db.Decimal(10, 2)
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  laborLines BomLaborLine[]
}

// Labor consumed by a parent (same polymorphic parent + CHECK as BomComponent).
model BomLaborLine {
  id String @id @default(cuid())

  productId        String?
  product          Product?        @relation(fields: [productId], references: [id], onDelete: Cascade)
  productVariantId String?
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  parentMaterialId String?
  parentMaterial   Material?       @relation("ParentMaterialLabor", fields: [parentMaterialId], references: [id], onDelete: Cascade)

  laborRateId String
  laborRate   LaborRate @relation(fields: [laborRateId], references: [id], onDelete: Restrict)
  hours       Decimal   @db.Decimal(10, 2) // per ONE unit of the parent
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([productVariantId])
  @@index([parentMaterialId])
  @@index([laborRateId])
}
